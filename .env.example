# Copie ce fichier en ".env" avant de builder / démarrer (jamais commité sur GitHub)

PORT=3000

# --- Frontend (URLs publiques, même origine puisque tout est fusionné) ---
NEXT_PUBLIC_API_BASE=https://groupegsi.mg/apk/api
NEXT_PUBLIC_MEDIA_BASE=https://groupegsi.mg
API_BASE=https://groupegsi.mg/apk/api
MEDIA_BASE=https://groupegsi.mg

# --- Backend / Base de données (utilisée directement, sans passer par rtmggmg) ---
DB_HOST=localhost
DB_NAME=groupegs_messenger-ai-agent
DB_USER=groupegs_messenger-ai-agent
DB_PASSWORD=CHANGE_MOI_MOT_DE_PASSE_MYSQL_REEL

# Génère une vraie valeur aléatoire avec :
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CHANGE_MOI_VALEUR_ALEATOIRE_LONGUE
JWT_EXPIRES_IN=12h

# Secret temporaire pour créer le premier admin / migrer les mots de passe
# SANS terminal (route POST /apk/api/setup/run). Utilise-le UNE FOIS puis
# SUPPRIME cette ligne et redémarre l'appli.
SETUP_TOKEN=CHANGE_MOI_AUSSI_ALEATOIRE_ET_LONG
